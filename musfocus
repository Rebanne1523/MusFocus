_RATBAG_BTN_NAME = {
    1: "BTN_LEFT", 2: "BTN_RIGHT", 3: "BTN_MIDDLE", 4: "BTN_SIDE",
    5: "BTN_EXTRA", 6: "BTN_FORWARD", 7: "BTN_BACK", 8: "BTN_TASK",
}
_BTN_FRIENDLY = {
    "BTN_LEFT":    "Left click (LMB)",
    "BTN_RIGHT":   "Right click (RMB)",
    "BTN_MIDDLE":  "Middle click",
    "BTN_SIDE":    "Back button (thumb, rear)",
    "BTN_EXTRA":   "Front button (thumb, front)",
    "BTN_FORWARD": "Modifier / DPI button",
    "BTN_BACK":    "Back",
    "BTN_TASK":    "Task button",
}


def _button_choices():
    """Scan the first ratbag device → [(index_str, friendly_description)] or None."""
    import re as _re
    result = subprocess.run(["ratbagctl", "list"], capture_output=True, text=True)
    if result.returncode != 0 or not result.stdout.strip():
        return None
    first = result.stdout.strip().splitlines()[0]
    name = first.split(":", 1)[1].strip() if ":" in first else first.strip()
    count_r = subprocess.run(
        ["ratbagctl", name, "profile", "0", "button", "count"],
        capture_output=True, text=True,
    )
    try:
        count = int(count_r.stdout.strip())
    except ValueError:
        return None
    out = []
    for i in range(count):
        br = subprocess.run(
            ["ratbagctl", name, "profile", "0", "button", str(i), "action", "get"],
            capture_output=True, text=True,
        )
        line = br.stdout.strip()
        m = _re.search(r"'button (\d+)'", line)
        if m:
            ev = _RATBAG_BTN_NAME.get(int(m.group(1)), f"button {m.group(1)}")
            desc = _BTN_FRIENDLY.get(ev, ev)
        elif "macro" in line.lower():
            desc = "currently a keyboard shortcut"
        else:
            desc = (line.split("'")[-2] if "'" in line else line) or "unmapped"
        out.append((str(i), desc))
    return out


def _pick_button_index():
    """Let the user pick a physical mouse button from a labeled list. Returns index str."""
    with Spinner("Reading your mouse buttons"):
        choices = _button_choices()
    if not choices:
        idx = _ask("Couldn't read the mouse. Type a button index instead")
        return idx if (idx and idx.isdigit()) else None
    labels = [f"{OR}[{i}]{RS}  {desc}" for i, desc in choices]
    pick = _select("Which button?", labels,
                   intro=["The text shows what each button does now."])
    if pick is None:
        return None
    return choices[pick][0]



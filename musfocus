def _choose_app_pattern():
    """Identify an app → return a match pattern, or None to skip."""
    how = _select("Which app is this profile for?", [
        "⊙ Detect the focused window  (recommended)",
        "✎ Type the pattern myself",
        f"{DM}Skip — assign an app later{RS}",
    ], intro=["A profile loads automatically when its app is focused."])
    if how is None or how == 2:

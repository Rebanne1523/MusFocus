            if not _set_button(var, idx, act):
                continue
            _save_doc(doc)
            _offer_reload()
        else:
            k = btn_keys[choice]
            act = _choose_action()
            if act is None:
                continue
            if act == "":
                del var[k]
            elif not _set_button(var, k, act):
                continue
            _save_doc(doc)
            _offer_reload()


def _variant_layer2(name, vn):
    """Second layer (hold-to-activate shortcuts) for one assignment."""
    while True:
        doc = _load_doc()
        var = doc["profile"][name]["variants"][vn]
        l2 = var.get("layer2") or {}
        binds = [(k, str(l2[k])) for k in l2 if k in _BTN_FRIENDLY]
        trig = next((k for k, v in var.items() if str(v) == "button:6"), None)
        trig_lbl = "not set" if trig is None else f"button {trig}"
        labels = [f"{DM}trigger{RS}  {OR}{trig_lbl}{RS} {DM}(hold this){RS}"]
        for k, v in binds:
            labels.append(f"{_BTN_FRIENDLY.get(k, k):<20} {DM}→{RS}  {OR}{v}{RS}")
        labels.append(f"{GR}+ add shortcut{RS}")
        choice = _select(f"{name}/{vn} · second layer", labels,
                         intro=["Hold the trigger, then click a button → fires a shortcut."],
                         footer="↑↓ move · enter select · q back")
        if choice is None:
            return

        def _l2(d):
            v = d["profile"][name]["variants"][vn]
            if v.get("layer2") is None:
                v["layer2"] = _tomlkit().table()
            return v["layer2"]

        if choice == 0:
            print(f"\n  {DM}Pick the button to HOLD for the second layer.{RS}")
            _pause("press any key to choose")
            bidx = _pick_button_index()
            if bidx:
                for k in [k for k, v in list(var.items())
                          if str(v) == "button:6" and str(k) != str(bidx)]:
                    del var[k]
                var[bidx] = "button:6"
                _save_doc(doc)
                _apply_now()
        elif 1 <= choice <= len(binds):
            k, v = binds[choice - 1]
            what = _select(f"{_BTN_FRIENDLY.get(k, k)}  →  {v}",
                           ["Change shortcut", f"{RD}Remove{RS}"])
            if what == 0:
                combo = _get_combo()
                if combo:
                    _l2(doc)[k] = combo
                    _save_doc(doc)
                    _apply_now()
            elif what == 1:
                if _confirm(f"Remove {_BTN_FRIENDLY.get(k, k)} → {v}?", default=False):
                    layer = _l2(doc)
                    if k in layer:
                        del layer[k]
                    _save_doc(doc)
                    _apply_now()
        elif choice == 1 + len(binds):
            btn = _pick_btn_name()
            if not btn:
                continue
            print(f"\n  {DM}Set the shortcut for {_BTN_FRIENDLY.get(btn, btn)}.{RS}")
            combo = _get_combo()
            if not combo:
                continue
            _l2(doc)[btn] = combo
            _save_doc(doc)
            _apply_now()


# ---- app mappings ----

def _detect_window_class():
    """Animated 5s wait, then read the focused window's class. Returns str or None."""
    import time
    print("\033[2J\033[H", end="")
    print_banner()
    _header("Detect window")
    print(f"  {DM}Click the app's window before the countdown ends.{RS}")
    print(f"\n  {YL}{BD}Focus your target window now...{RS}")
    width, dots = 14, Spinner.DOTS
    span = 2 * (width - 1)
    if _TTY:
        sys.stdout.write("\033[?25l")
    end, i = time.time() + 5, 0
    while time.time() < end:
        remain = end - time.time()
        dot = dots[i % len(dots)]
        pos = i % span
        if pos >= width:
            pos = span - pos
        track = "".join((OR + "█" + RS) if j == pos else (DM + "·" + RS) for j in range(width))
        sys.stdout.write(
            f"\r  {OR}{BD}{dot}{RS} reading in {YL}{BD}{remain:0.0f}s{RS} "
            f"{OR2}❮{RS}{track}{OR2}❯{RS} "
        )
        sys.stdout.flush()
        time.sleep(0.07)
        i += 1
    if _TTY:
        sys.stdout.write("\r\033[K\033[?25h")
    try:
        with open("/tmp/FocusNotifier/wclass.txt") as f:
            return f.read().strip()
    except FileNotFoundError:
        return None


def _pick_profile(doc, title="Assign to which profile?"):
    """Let the user pick an existing profile or create one. Returns name or None."""
    profs = list(doc.get("profile", {}).keys())
    pick = _select(title, [f"{OR}{p}{RS}" for p in profs] + [f"{GR}+ new profile{RS}"])
    if pick is None:
        return None
    if pick == len(profs):
        return _new_profile()
    return profs[pick]


def _apps_screen():
    while True:
        doc = _load_doc()
        apps = doc.get("apps", {})
        patterns = list(apps.keys())
        labels = [f"{DM}{p}{RS}  {OR}→ {apps[p]}{RS}" for p in patterns]
        labels.append(f"{GR}+ new app mapping{RS}")
        choice = _select("App mappings", labels,
                         intro=["When an app is focused, load its profile (else 'default')."],
                         footer="↑↓ · enter · q back")
        if choice is None:
            return
        if choice == len(patterns):
            _new_app_mapping()
        else:
            _edit_app_mapping(patterns[choice])


def _new_app_mapping():
    how = _select("New app mapping  ·  1/3 · find the app", [
        "⊙ Detect the focused window  (recommended)",
        "✎ Type the pattern manually",
    ], intro=["Step 1: identify the app."])
    if how is None:
        return
    wclass = None
    if how == 0:
        wclass = _detect_window_class()
        if wclass is None:
            print(f"\n  {RD}No window class read{RS} {DM}— type one instead.{RS}")
            _pause()
        else:
            print(f"\n  {GR}✓{RS} Detected: {OR}{BD}{wclass}{RS}")
            _pause()
    default_pat = f"*{wclass.lower()}*" if wclass else ""
    pattern = _ask("2/3 · pattern  (* = wildcard, | = or)", default_pat)
    if not pattern:
        return
    doc = _load_doc()
    profile = _pick_profile(doc, title="3/3 · which profile?")
    if profile is None:
        return
    doc = _load_doc()  # reload in case a profile was just created
    if doc.get("apps") is None:
        doc["apps"] = _tomlkit().table()
    doc["apps"][pattern] = profile
    _save_doc(doc)
    print(f"\n  {GR}✓{RS} {DM}{pattern}{RS} {OR}→ {profile}{RS}")
    _pause()


def _edit_app_mapping(pattern):
    doc = _load_doc()
    apps = doc.get("apps", {})
    choice = _select(f"Mapping: {pattern}", [
        f"{DM}change pattern{RS}",
        f"{DM}change profile{RS}  {OR}(now: {apps.get(pattern)}){RS}",
        f"{RD}delete mapping{RS}",
    ])
    if choice is None:
        return
    if choice == 0:
        new = _ask("New pattern", pattern)
        if new and new != pattern:
            val = apps[pattern]
            del doc["apps"][pattern]
            doc["apps"][new] = val
            _save_doc(doc)
    elif choice == 1:
        profile = _pick_profile(doc, title="Change to which profile?")
        if profile is not None:
            doc = _load_doc()
            doc["apps"][pattern] = profile
            _save_doc(doc)
    elif choice == 2:
        if _confirm(f"Delete mapping {pattern!r}?", default=False):
            del doc["apps"][pattern]
            _save_doc(doc)


# ---- device ----

def _device_screen():
    def _list_inputs():
        out = []
        try:
            import evdev as _evdev
        except ImportError:
            return out
        seen = set()
        for path in _evdev.list_devices():
            try:
                d = _evdev.InputDevice(path)
                if d.info.vendor and d.info.product:
                    key = (d.info.vendor, d.info.product)
                    if key not in seen:
                        seen.add(key)
                        out.append((format(d.info.vendor, "04x"),
                                    format(d.info.product, "04x"), d.name))
                d.close()
            except Exception:
                pass
        return out

    with Spinner("Scanning input devices"):
        devs = _list_inputs()
    if not devs:
        print(f"\n  {RD}No input devices found.{RS}")
        _pause()
        return
    doc = _load_doc()
    cur = doc.get("device", {})
    curv, curp = cur.get("vendor"), cur.get("product")

    def looks_like_mouse(n):
        return "mouse" in n.lower() or any(w in n.lower() for w in ("g305", "g pro", "gaming mouse"))

    labels = []
    for vid, pid, name in devs:
        tag = ""
        if vid == curv and pid == curp:
            tag = f"{GR}  ✓ current{RS}"
        elif looks_like_mouse(name):
            tag = f"{OR2}  · mouse?{RS}"
        labels.append(f"{OR}{vid}:{pid}{RS}  {name}{tag}")
    pick = _select("Pick your mouse", labels,
                   intro=["Pick your MOUSE (not the keyboard). · = likely mouse."])
    if pick is None:
        return
    vid, pid, name = devs[pick]
    if not looks_like_mouse(name) and not _confirm(
            f"{name!r} doesn't look like a mouse. Use it anyway?", default=False):
        return
    if doc.get("device") is None:
        doc["device"] = _tomlkit().table()
    doc["device"]["vendor"] = vid
    doc["device"]["product"] = pid
    _save_doc(doc)
    print(f"\n  {GR}✓{RS} Mouse set to {OR}{name}{RS}")
    _offer_reload()


# evdev buttons that can fire a second-layer shortcut (the trigger itself excluded).
_MOD_TARGETS = ["BTN_SIDE", "BTN_EXTRA", "BTN_RIGHT", "BTN_MIDDLE", "BTN_BACK", "BTN_LEFT"]


def _pick_btn_name(exclude=("BTN_FORWARD",)):
    """Pick which button fires a second-layer shortcut. Returns a BTN_ name."""
    names = [n for n in _MOD_TARGETS if n not in exclude]
    labels = [f"{OR}{_BTN_FRIENDLY.get(n, n)}{RS}" for n in names]
    pick = _select("Which button fires it?", labels,
                   intro=["Hold the trigger, then click this button."])
    return names[pick] if pick is not None else None


def cmd_config_menu(args):
    """Interactive CRUD editor for config.toml, reachable from the main menu."""
    if not (_TTY and sys.stdin.isatty()):
        print_banner()
        cmd_list(args)
        return
    while True:
        choice = _select("Configuration", [
            f"{BD}Profiles{RS}      {DM}buttons, shortcuts & the app each is for{RS}",
            f"{BD}Device{RS}        {DM}choose your mouse{RS}",
            f"{DM}Edit config.toml in your editor{RS}",
        ], intro=["Changes save and apply automatically.",
                  "App assignment lives inside each profile (create one to set it)."],
           footer="↑↓ move · enter open · q back to main menu")

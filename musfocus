def _run_menu_item(idx):
    print("\033[2J\033[H", end="")        # clear screen
    print_banner()
    _MENU[idx][2](_NS())
    print(f"\n{DM}  ── press any key to return to the menu ──{RS}", end="", flush=True)
    _read_key()


def cmd_menu(args):
    """Interactive arrow-key menu shown when musfocus is run with no command."""
    if not (_TTY and sys.stdin.isatty()):
        print_banner()
        cmd_status(args)
        return

    idx = 0
    while True:
        print("\033[2J\033[H", end="")    # clear screen + home
        print_banner()
        print()
        for i, (name, desc, _) in enumerate(_MENU):
            num = f"{OR2}{i + 1}{RS}"
            if i == idx:
                print(f"  {OR}{BD}›{RS} {num}  {OR}{BD}{name:<8}{RS} {DM}{desc}{RS}")
            else:
                print(f"    {num}  {name:<8} {DM}{desc}{RS}")
        print(f"\n  {DM}↑↓ move · enter select · 1-{len(_MENU)} jump · q quit{RS}")

        try:
            key = _read_key()
        except (KeyboardInterrupt, EOFError):
            break
        if key in ("q", "Q", "esc", "\x03"):
            break
        elif key == "up":
            idx = (idx - 1) % len(_MENU)
        elif key == "down":
            idx = (idx + 1) % len(_MENU)
        elif key in ("\r", "\n"):
            _run_menu_item(idx)
        elif key.isdigit() and 1 <= int(key) <= len(_MENU):
            idx = int(key) - 1
            _run_menu_item(idx)

    print("\033[2J\033[H", end="")
    print(f"{OR}musfocus{RS} {DM}— bye{RS}")


def main():
    parser = argparse.ArgumentParser(
        prog="musfocus",
        description="Per-app mouse profile switcher for any ratbagd-supported mouse.",
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("status", help="Show current profile and service status")
    sub.add_parser("list",   help="List all profiles, app mappings, and shortcuts")
    sub.add_parser("config", help="Open config.toml in your editor ($EDITOR or nano)")
    sub.add_parser("reload", help="Restart the modifier daemon and clear profile cache")
    sub.add_parser("menu",   help="Open the interactive menu (default with no command)")

    p_apply = sub.add_parser("apply", help="Apply a profile manually")
    p_apply.add_argument("profile", help="Profile name from config.toml")

    p_detect = sub.add_parser("detect", help="Detect device info or current window class")
    p_detect.add_argument(
        "--window", action="store_true",
        help="Show the current window's class (for adding app mappings)",
    )

    args = parser.parse_args()

    # No command → interactive menu. The menu draws its own banner per redraw.
    if args.command in (None, "menu"):
        cmd_menu(args)
        return

    # Every other command leads with the banner.
    print_banner()
    {
        "status": cmd_status,
        "list":   cmd_list,
        "config": cmd_config,
        "apply":  cmd_apply,
        "reload": cmd_reload,
        "detect": cmd_detect,
    }[args.command](args)


if __name__ == "__main__":
    main()

class Spinner:
    """A playful orange 'scanner' animation shown while slow work runs.

    Usage:
        with Spinner("Scanning devices"):
            slow_work()
    Falls back to a single static line when stdout isn't a TTY.
    """
    DOTS = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]

    def __init__(self, label, width=14):
        self.label = label
        self.width = width
        import threading
        self._stop = threading.Event()
        self._thread = None

    def __enter__(self):
        if not _TTY:
            print(f"  {self.label}...", flush=True)
            return self
        import threading
        sys.stdout.write("\033[?25l")  # hide cursor
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()
        return self

    def _run(self):
        import time
        span = 2 * (self.width - 1)
        i = 0
        while not self._stop.is_set():
            dot = self.DOTS[i % len(self.DOTS)]
            pos = i % span
            if pos >= self.width:
                pos = span - pos                     # bounce back
            track = "".join(
                f"{OR}█{RS}" if j == pos else f"{DM}·{RS}"
                for j in range(self.width)
            )
            sys.stdout.write(f"\r  {OR}{BD}{dot}{RS} {self.label} {OR2}❮{RS}{track}{OR2}❯{RS} ")
            sys.stdout.flush()
            time.sleep(0.07)
            i += 1

    def __exit__(self, *exc):
        if not _TTY:
            return False
        self._stop.set()
        if self._thread:
            self._thread.join()
        sys.stdout.write("\r\033[K\033[?25h")        # clear line, restore cursor
        sys.stdout.flush()
        return False


def load_config():
    try:
        with open(CONFIG_PATH, "rb") as f:
            return tomllib.load(f)
    except FileNotFoundError:
        print(f"{RD}Config not found:{RS} {CONFIG_PATH}", file=sys.stderr)
        print("Run install.sh or copy config.toml.example to config.toml.", file=sys.stderr)
        sys.exit(1)


def cmd_status(args):
    try:
        with open(CACHE_FILE) as f:
            current = f.read().strip()
    except FileNotFoundError:
        current = f"{DM}unknown — no switch yet{RS}"

    result = subprocess.run(
        ["systemctl", "--user", "is-active", SERVICE],
        capture_output=True, text=True,
    )
    daemon_status = result.stdout.strip()
    daemon_color  = GR if daemon_status == "active" else RD

    config   = load_config()
    dev      = config.get("device", {})
    profiles = list(config.get("profile", {}).keys())
    apps     = config.get("apps", {})

    _header("musfocus status")
    print(f"  {DM}Active profile {RS}  {OR}{BD}{current}{RS}")
    print(f"  {DM}Modifier daemon{RS}  {daemon_color}{BD}{daemon_status}{RS}")
    print(f"  {DM}Device         {RS}  {OR}{dev.get('vendor','?')}:{dev.get('product','?')}{RS}")
    print(f"  {DM}Profiles       {RS}  {', '.join(f'{OR}{p}{RS}' for p in profiles)}")
    print(f"  {DM}App mappings   {RS}  {len(apps)} rule(s)")
    print()


def cmd_list(args):
    config = load_config()

    global_mod = config.get("modifier", {})

    _header("Profiles")
    for name, prof in config.get("profile", {}).items():
        dpi = prof.get("dpi")
        print(f"  {OR}{BD}{name}{RS}  {DM}dpi {dpi}{RS}" if dpi else f"  {OR}{BD}{name}{RS}")
        for btn, action in prof.items():
            if btn in ("dpi", "layer2"):
                continue
            print(f"    {DM}button {btn}{RS}  {DM}→{RS}  {action}")
        layer = prof.get("layer2", global_mod)
        for k, v in layer.items():
            if k.startswith("BTN_"):
                print(f"    {DM}hold +{RS} {k:<10} {DM}→{RS}  {OR}{v}{RS}")

    _header("App mappings")
    apps = config.get("apps", {})
    if apps:
        for pattern, profile in apps.items():
            print(f"  {DM}{pattern!r}{RS}  {DM}→{RS}  {OR}{profile}{RS}")
    else:
        print(f"  {DM}(none — all apps use 'default' profile){RS}")
    print()


def cmd_apply(args):
    config = load_config()
    if args.profile not in config.get("profile", {}):
        print(f"{RD}Unknown profile:{RS} {args.profile}", file=sys.stderr)
        print(f"  Available: {', '.join(config.get('profile', {}))}", file=sys.stderr)
        sys.exit(1)
    # The daemon watches this file and swaps its software remap instantly.
    tmp = CACHE_FILE + ".tmp"
    with open(tmp, "w") as f:
        f.write(args.profile)
    os.replace(tmp, CACHE_FILE)
    print(f"{GR}✓{RS} Profile: {OR}{BD}{args.profile}{RS}  {DM}(applied instantly){RS}")


def cmd_config(args):
    editor = (
        os.environ.get("EDITOR")
        or os.environ.get("VISUAL")
        or "nano"
    )
    subprocess.run([editor, CONFIG_PATH])


def cmd_reload(args):
    print(f"{OR}Restarting {SERVICE}...{RS}")
    subprocess.run(["systemctl", "--user", "restart", SERVICE])

    try:
        os.remove(CACHE_FILE)
    except FileNotFoundError:
        pass

    print(f"{GR}✓{RS} Done. Profile will re-apply on next window focus change.")
    print(f"  Or run: {OR}musfocus apply default{RS}")


def cmd_detect(args):
    if args.window:
        import time
        print(f"{YL}{BD}Switch to (or hover over) your target window now...{RS}")
        for i in range(5, 0, -1):
            print(f"{YL}  Reading in {BD}{i}s{RS}{YL}...{RS}", end="\r", flush=True)
            time.sleep(1)
        print(" " * 40, end="\r", flush=True)
        try:
            with open("/tmp/FocusNotifier/wclass.txt") as f:
                wclass = f.read().strip()
            print(f"  Window class  {OR}{BD}{wclass}{RS}")
            print()
            print(f"{DM}Add to config.toml:{RS}")
            print(f"  {DM}[apps]{RS}")
            print(f'  {OR}"*{wclass.lower()}*"{RS} = {OR}"myprofile"{RS}')
            print()
            print(f"  {DM}[profile.myprofile]{RS}")
            print(f'  {DM}3 = "key:Backspace"{RS}')
            print(f'  {DM}4 = "key:Ctrl+B"{RS}')
            print(f'  {DM}5 = "button:6"{RS}')
        except FileNotFoundError:
            print(f"{RD}FocusNotifier is not running or no window has been focused yet.{RS}")
        return

    BTN_NAME = {
        1: "BTN_LEFT",   2: "BTN_RIGHT",   3: "BTN_MIDDLE",
        4: "BTN_SIDE",   5: "BTN_EXTRA",   6: "BTN_FORWARD",
        7: "BTN_BACK",   8: "BTN_TASK",
    }
    BTN_LABEL = {
        "BTN_LEFT":    "left click",
        "BTN_RIGHT":   "right click",
        "BTN_MIDDLE":  "middle",
        "BTN_SIDE":    "back (thumb, rear)",
        "BTN_EXTRA":   "front (thumb, front)",
        "BTN_FORWARD": "modifier trigger",
        "BTN_BACK":    "back",
    }

    _header("Ratbagd devices")

    import re as _re

    def _gather_ratbag():
        data = {"error": None, "devices": []}
        result = subprocess.run(["ratbagctl", "list"], capture_output=True, text=True)
        if result.returncode != 0 or not result.stdout.strip():
            data["error"] = "nodev"
            return data
        for line in result.stdout.strip().splitlines():
            line = line.strip()
            if not line:
                continue
            name = line.split(":", 1)[1].strip() if ":" in line else line
            if not name:
                continue
            dev = {"name": name, "count_error": False, "buttons": []}
            count_r = subprocess.run(
                ["ratbagctl", name, "profile", "0", "button", "count"],
                capture_output=True, text=True,
            )
            try:
                count = int(count_r.stdout.strip())
            except ValueError:
                dev["count_error"] = True
                data["devices"].append(dev)
                continue
            for i in range(count):
                br = subprocess.run(
                    ["ratbagctl", name, "profile", "0", "button", str(i), "action", "get"],
                    capture_output=True, text=True,
                )
                dev["buttons"].append((i, br.stdout.strip()))
            data["devices"].append(dev)
        return data

    with Spinner("Scanning ratbagd devices"):
        data = _gather_ratbag()

    if data["error"] == "nodev":
        print(f"  {RD}No devices found. Is ratbagd running?{RS}")
        print(f"  Try: {OR}sudo systemctl start ratbagd{RS}")
    else:
        for dev in data["devices"]:
            print(f"  {BD}{dev['name']}{RS}")
        print()
        for dev in data["devices"]:
            print(f"  {OR}{BD}Button indices{RS} {DM}for {dev['name']!r}{RS}")
            if dev["count_error"]:
                print(f"    {RD}(could not read button count){RS}")
                print()
                continue
            for i, line in dev["buttons"]:
                if not line:
                    continue
                m = _re.search(r"'button (\d+)'", line)
                if m:
                    btn_num    = int(m.group(1))
                    evdev_name = BTN_NAME.get(btn_num, f"button {btn_num}")
                    label      = BTN_LABEL.get(evdev_name, "")
                    print(
                        f"    {DM}[{i}]{RS}  "
                        f"{OR}button:{btn_num:<2}{RS}  "
                        f"{DM}→{RS}  "
                        f"{BD}{evdev_name:<14}{RS}  "
                        f"{DM}({label}){RS}"
                    )
                else:
                    action = line.split("'")[-2] if "'" in line else line
                    print(f"    {DM}[{i}]{RS}  {action}")
            print()

    _header("Input device VID:PIDs")
    print(f"  {DM}Use these in config.toml — more accurate than lsusb for wireless mice.{RS}\n")
    try:
        import evdev as _evdev
        seen = set()
        for path in _evdev.list_devices():
            try:
                d = _evdev.InputDevice(path)
                if d.info.vendor and d.info.product:
                    key = (d.info.vendor, d.info.product)
                    if key not in seen:
                        seen.add(key)
                        vid = format(d.info.vendor, "04x")
                        pid = format(d.info.product, "04x")
                        print(f"  {OR}{vid}:{pid}{RS}  {d.name}")
                d.close()
            except Exception:
                pass
        if not seen:
            print(f"  {DM}(no input devices found){RS}")
    except ImportError:
        print(f"  {DM}(python-evdev not installed, falling back to lsusb){RS}")
        result = subprocess.run(["lsusb"], capture_output=True, text=True)
        for line in result.stdout.strip().splitlines():
            print(f"  {line}")

    print()
    print(f"  {DM}Set in config.toml:{RS}")
    print(f"  {DM}[device]{RS}")
    print(f'  {OR}vendor{RS}  {DM}={RS} {OR2}"046d"{RS}')
    print(f'  {OR}product{RS} {DM}={RS} {OR2}"4074"{RS}')
    print()



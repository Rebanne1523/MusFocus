#!/usr/bin/env python3
"""musfocus — per-app mouse profile switcher for any ratbagd-supported mouse."""
import argparse, os, sys, subprocess, tomllib

INSTALL_DIR = os.path.dirname(os.path.realpath(__file__))
CONFIG_PATH = os.path.join(INSTALL_DIR, "config.toml")
SRC_DIR     = os.path.join(INSTALL_DIR, "src")
CACHE_FILE  = "/tmp/musfocus-cache"
SERVICE     = "musfocus-modifier"


def load_config():
    try:
        with open(CONFIG_PATH, "rb") as f:
            return tomllib.load(f)
    except FileNotFoundError:
        print(f"Config not found: {CONFIG_PATH}", file=sys.stderr)
        print("Run install.sh or copy config.toml.example to config.toml.", file=sys.stderr)
        sys.exit(1)


def cmd_status(args):
    try:
        with open(CACHE_FILE) as f:
            current = f.read().strip()
    except FileNotFoundError:
        current = "(unknown — no switch has happened yet)"

    result = subprocess.run(
        ["systemctl", "--user", "is-active", SERVICE],
        capture_output=True, text=True,
    )
    daemon_status = result.stdout.strip()

    config = load_config()
    dev    = config.get("device", {})
    profiles = list(config.get("profile", {}).keys())
    apps = config.get("apps", {})

    print(f"Active profile : {current}")
    print(f"Modifier daemon: {daemon_status}")
    print(f"Device VID:PID : {dev.get('vendor', '?')}:{dev.get('product', '?')}")
    print(f"Profiles       : {', '.join(profiles)}")
    print(f"App mappings   : {len(apps)} rule(s)")


def cmd_list(args):
    config = load_config()

    print("Profiles:")
    for name, buttons in config.get("profile", {}).items():
        print(f"  {name}:")
        for btn, action in buttons.items():
            print(f"    button {btn} -> {action}")

    print()
    print("App mappings:")
    apps = config.get("apps", {})
    if apps:
        for pattern, profile in apps.items():
            print(f"  {pattern!r} -> {profile}")
    else:
        print("  (none — all apps use 'default' profile)")

    print()
    print("Modifier shortcuts (hold DPI button + click):")
    mod = config.get("modifier", {})
    for key, val in mod.items():
        if key != "button":
            print(f"  {key} -> {val}")


def cmd_apply(args):
    apply_py = os.path.join(SRC_DIR, "apply.py")
    result = subprocess.run([sys.executable, apply_py, args.profile])
    if result.returncode == 0:
        with open(CACHE_FILE, "w") as f:
            f.write(args.profile)
        print(f"Profile applied: {args.profile}")
    else:
        sys.exit(result.returncode)


def cmd_config(args):
    editor = (
        os.environ.get("EDITOR")
        or os.environ.get("VISUAL")
        or "nano"
    )
    os.execvp(editor, [editor, CONFIG_PATH])


def cmd_reload(args):
    print(f"Restarting {SERVICE}...")
    subprocess.run(["systemctl", "--user", "restart", SERVICE])

    try:
        os.remove(CACHE_FILE)
    except FileNotFoundError:
        pass

    print("Done. Profile will re-apply on next window focus change.")
    print("Or run: musfocus apply default")


def cmd_detect(args):
    if args.window:
        try:
            with open("/tmp/FocusNotifier/wclass.txt") as f:
                wclass = f.read().strip()
            print(f"Current window class: {wclass!r}")
            print()
            print("To add a profile for this app, add to config.toml:")
            print(f'  [apps]')
            print(f'  "*{wclass.lower()}*" = "myprofile"')
            print()
            print(f'  [profile.myprofile]')
            print(f'  3 = "key:Backspace"')
            print(f'  4 = "key:Ctrl+B"')
            print(f'  5 = "button:6"')
        except FileNotFoundError:
            print("FocusNotifier is not running or no window has been focused yet.")
        return

    # ratbagd devices + button indices
    print("Ratbagd-supported devices:")
    result = subprocess.run(["ratbagctl", "list"], capture_output=True, text=True)
    if result.returncode != 0 or not result.stdout.strip():
        print("  No devices found. Is ratbagd running?")
        print("  Try: sudo systemctl start ratbagd")
    else:
        devices = []
        for line in result.stdout.strip().splitlines():
            line = line.strip()
            if not line:
                continue
            # "bellowing-paca:      Logitech G305" → "Logitech G305"
            name = line.split(":", 1)[1].strip() if ":" in line else line
            if name:
                devices.append(name)
                print(f"  {name}")
        print()
        # Maps ratbagd "button N" action → evdev BTN_* name used in [modifier] config
        BTN_NAME = {
            1: "BTN_LEFT",   2: "BTN_RIGHT",   3: "BTN_MIDDLE",
            4: "BTN_SIDE",   5: "BTN_EXTRA",   6: "BTN_FORWARD",
            7: "BTN_BACK",   8: "BTN_TASK",
        }
        BTN_LABEL = {
            "BTN_LEFT": "left click",    "BTN_RIGHT": "right click",
            "BTN_MIDDLE": "middle",      "BTN_SIDE": "back (side)",
            "BTN_EXTRA": "forward (extra)", "BTN_FORWARD": "modifier trigger",
            "BTN_BACK": "back",
        }

        for name in devices:
            print(f"  Button indices for '{name}':")
            count_r = subprocess.run(
                ["ratbagctl", name, "profile", "0", "button", "count"],
                capture_output=True, text=True,
            )
            try:
                count = int(count_r.stdout.strip())
            except ValueError:
                print("    (could not read button count)")
                print()
                continue
            for i in range(count):
                br = subprocess.run(
                    ["ratbagctl", name, "profile", "0", "button", str(i), "action", "get"],
                    capture_output=True, text=True,
                )
                line = br.stdout.strip()
                if not line:
                    continue
                # Parse "Button: N is mapped to 'button M'" → extract M
                import re as _re
                m = _re.search(r"'button (\d+)'", line)
                if m:
                    btn_num = int(m.group(1))
                    evdev_name = BTN_NAME.get(btn_num, f"button {btn_num}")
                    label = BTN_LABEL.get(evdev_name, "")
                    print(f"    [{i}]  button:{btn_num:<2}  →  {evdev_name:<14}  ({label})")
                else:
                    # macro or special action — show raw action
                    action = line.split("'")[-2] if "'" in line else line
                    print(f"    [{i}]  {action}")
            print()

    # evdev listing — the correct VID:PID source, especially for wireless mice
    print("Input device VID:PIDs (use these in config.toml, not lsusb for wireless mice):")
    try:
        import evdev as _evdev
        seen = set()
        for path in _evdev.list_devices():
            try:
                d = _evdev.InputDevice(path)
                if d.info.vendor and d.info.product:
                    key = (d.info.vendor, d.info.product)
                    if key not in seen:
                        seen.add(key)
                        vid = format(d.info.vendor, "04x")
                        pid = format(d.info.product, "04x")
                        print(f"  {vid}:{pid}  {d.name}")
                d.close()
            except Exception:
                pass
        if not seen:
            print("  (no input devices found)")
    except ImportError:
        print("  (python-evdev not installed, falling back to lsusb)")
        result = subprocess.run(["lsusb"], capture_output=True, text=True)
        for line in result.stdout.strip().splitlines():
            print(f"  {line}")

    print()
    print("Set in config.toml:")
    print("  [device]")
    print('  vendor  = "046d"')
    print('  product = "4074"')


def main():
    parser = argparse.ArgumentParser(
        prog="musfocus",
        description="Per-app mouse profile switcher for any ratbagd-supported mouse.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("status", help="Show current profile and service status")
    sub.add_parser("list",   help="List all profiles, app mappings, and shortcuts")
    sub.add_parser("config", help="Open config.toml in your editor ($EDITOR or nano)")
    sub.add_parser("reload", help="Restart the modifier daemon and clear profile cache")

    p_apply = sub.add_parser("apply", help="Apply a profile manually")
    p_apply.add_argument("profile", help="Profile name from config.toml")

    p_detect = sub.add_parser("detect", help="Detect device info or current window class")
    p_detect.add_argument(
        "--window", action="store_true",
        help="Show the current window's class (for adding app mappings)",
    )

    args = parser.parse_args()
    {
        "status": cmd_status,
        "list":   cmd_list,
        "config": cmd_config,
        "apply":  cmd_apply,
        "reload": cmd_reload,
        "detect": cmd_detect,
    }[args.command](args)


if __name__ == "__main__":
    main()

def _new_app_mapping():
    how = _select("New app mapping  ·  1/3 · find the app", [
        "⊙ Detect the focused window  (recommended)",
        "✎ Type the pattern manually",
    ], intro=["Step 1: identify the app."])
    if how is None:
        return
    wclass = None
    if how == 0:
        wclass = _detect_window_class()
        if wclass is None:
            print(f"\n  {RD}No window class read{RS} {DM}— type one instead.{RS}")
            _pause()
        else:
            print(f"\n  {GR}✓{RS} Detected: {OR}{BD}{wclass}{RS}")
            _pause()
    default_pat = f"*{wclass.lower()}*" if wclass else ""
    pattern = _ask("2/3 · pattern  (* = wildcard, | = or)", default_pat)
    if not pattern:
        return
    doc = _load_doc()
    profile = _pick_profile(doc, title="3/3 · which profile?")
    if profile is None:
        return
    doc = _load_doc()  # reload in case a profile was just created
    if doc.get("apps") is None:
        doc["apps"] = _tomlkit().table()
    doc["apps"][pattern] = profile
    _save_doc(doc)
    print(f"\n  {GR}✓{RS} {DM}{pattern}{RS} {OR}→ {profile}{RS}")
    _pause()


def _edit_app_mapping(pattern):
    doc = _load_doc()
    apps = doc.get("apps", {})
    choice = _select(f"Mapping: {pattern}", [
        f"{DM}change pattern{RS}",
        f"{DM}change profile{RS}  {OR}(now: {apps.get(pattern)}){RS}",
        f"{RD}delete mapping{RS}",
    ])
    if choice is None:
        return
    if choice == 0:
        new = _ask("New pattern", pattern)
        if new and new != pattern:
            val = apps[pattern]
            del doc["apps"][pattern]
            doc["apps"][new] = val
            _save_doc(doc)
    elif choice == 1:
        profile = _pick_profile(doc, title="Change to which profile?")
        if profile is not None:
            doc = _load_doc()
            doc["apps"][pattern] = profile
            _save_doc(doc)
    elif choice == 2:
        if _confirm(f"Delete mapping {pattern!r}?", default=False):
            del doc["apps"][pattern]
            _save_doc(doc)


# ---- device ----

def _device_screen():
    def _list_inputs():
        out = []
        try:
            import evdev as _evdev
        except ImportError:
            return out
        seen = set()
        for path in _evdev.list_devices():
            try:
                d = _evdev.InputDevice(path)
                if d.info.vendor and d.info.product:
                    key = (d.info.vendor, d.info.product)
                    if key not in seen:
                        seen.add(key)
                        out.append((format(d.info.vendor, "04x"),
                                    format(d.info.product, "04x"), d.name))
                d.close()
            except Exception:
                pass
        return out

    with Spinner("Scanning input devices"):
        devs = _list_inputs()
    if not devs:
        print(f"\n  {RD}No input devices found.{RS}")
        _pause()
        return
    doc = _load_doc()
    cur = doc.get("device", {})
    curv, curp = cur.get("vendor"), cur.get("product")

    def looks_like_mouse(n):
        return "mouse" in n.lower() or any(w in n.lower() for w in ("g305", "g pro", "gaming mouse"))

    labels = []
    for vid, pid, name in devs:
        tag = ""
        if vid == curv and pid == curp:
            tag = f"{GR}  ✓ current{RS}"
        elif looks_like_mouse(name):
            tag = f"{OR2}  · mouse?{RS}"
        labels.append(f"{OR}{vid}:{pid}{RS}  {name}{tag}")
    pick = _select("Pick your mouse", labels,
                   intro=["Pick your MOUSE (not the keyboard). · = likely mouse."])
    if pick is None:
        return
    vid, pid, name = devs[pick]
    if not looks_like_mouse(name) and not _confirm(
            f"{name!r} doesn't look like a mouse. Use it anyway?", default=False):
        return
    if doc.get("device") is None:
        doc["device"] = _tomlkit().table()
    doc["device"]["vendor"] = vid
    doc["device"]["product"] = pid
    _save_doc(doc)
    print(f"\n  {GR}✓{RS} Mouse set to {OR}{name}{RS}")
    _offer_reload()


# evdev buttons that can fire a second-layer shortcut (the trigger itself excluded).
_MOD_TARGETS = ["BTN_SIDE", "BTN_EXTRA", "BTN_RIGHT", "BTN_MIDDLE", "BTN_BACK", "BTN_LEFT"]


def _pick_btn_name(exclude=("BTN_FORWARD",)):
    """Pick which button fires a second-layer shortcut. Returns a BTN_ name."""
    names = [n for n in _MOD_TARGETS if n not in exclude]
    labels = [f"{OR}{_BTN_FRIENDLY.get(n, n)}{RS}" for n in names]
    pick = _select("Which button fires it?", labels,
                   intro=["Hold the trigger, then click this button."])
    return names[pick] if pick is not None else None



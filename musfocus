    pick = _select("Which mouse function?", [f"{OR}{lbl}{RS}" for lbl, _ in _MOUSE_FUNCS],
                   intro=["Make this button act as a normal mouse button."])
    return _MOUSE_FUNCS[pick][1] if pick is not None else None


def _choose_action():
    """Action picker. Returns an action string, '' to remove, or None to cancel."""
    opt = _select("What should this button do?", [
        f"{OR}Mouse button{RS}          {DM}left, right, middle, back, front{RS}",
        f"{OR}Keyboard macro{RS}        {DM}Ctrl+C, Backspace, ...{RS}",
        f"{OR}Second-layer trigger{RS}  {DM}hold it to reach the 2nd layer{RS}",
        f"{RD}Remove{RS}",
    ], intro=["↑↓ to move, Enter to choose."])
    if opt is None:
        return None
    if opt == 0:
        return _choose_mouse_button()
    if opt == 1:
        combo = _get_combo()
        return f"key:{combo}" if combo else None
    if opt == 2:
        return "button:6"          # the second-layer trigger
    return ""  # remove


def _set_button(table, key, act):
    """Write a button action, keeping only ONE second-layer trigger. Returns applied?"""
    if act == "button:6":
        existing = [k for k, v in table.items() if str(v) == "button:6" and str(k) != str(key)]
        if existing:
            print(f"\n  {YL}Button {existing[0]} is already the second-layer trigger.{RS}")
            if not _confirm(f"Move the trigger to button {key} instead?", default=True):
                return False
            for k in existing:
                del table[k]
    table[key] = act
    return True



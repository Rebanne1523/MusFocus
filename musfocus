def _tomlkit():
    try:
        import tomlkit
        return tomlkit
    except ImportError:
        return None


def _require_tomlkit():
    if _tomlkit() is None:
        print(f"\n  {RD}Editing needs the 'tomlkit' package (not installed).{RS}")
        print(f"  Install it with:  {OR}sudo pacman -S python-tomlkit{RS}")
        print(f"  {DM}(it lets musfocus rewrite config.toml without losing your comments){RS}")
        _pause()
        return False
    return True


def _load_doc():
    with open(CONFIG_PATH) as f:
        return _tomlkit().parse(f.read())


def _save_doc(doc):
    with open(CONFIG_PATH, "w") as f:
        f.write(_tomlkit().dumps(doc))


def _pause(msg="press any key to continue"):
    print(f"\n{DM}  ── {msg} ──{RS}", end="", flush=True)
    _read_key()


def _ask(prompt, default=""):
    """Cooked-mode single-line input. Returns text (or the default), None if aborted."""
    sys.stdout.write(f"\n  {OR}{prompt}{RS}")
    if default:
        sys.stdout.write(f" {DM}[{default}]{RS}")
    sys.stdout.write(f"\n  {OR}›{RS} ")
    sys.stdout.flush()
    try:
        s = input().strip()
    except (EOFError, KeyboardInterrupt):
        return None
    return s if s else default


def _confirm(prompt, default=True):
    hint = "Y/n" if default else "y/N"
    r = _ask(f"{prompt} ({hint})", "")
    if r is None:
        return False
    r = r.lower()
    if r == "":
        return default
    return r in ("y", "yes", "s", "si", "sí")


def _select(title, labels, footer="↑↓ move · enter select · q back", intro=None):
    """Generic arrow-key selector over `labels`. Returns the chosen index, or None.

    `intro` is an optional list of dim help lines shown under the title.
    """
    if not (_TTY and sys.stdin.isatty()):
        return None
    idx = 0
    while True:
        print("\033[2J\033[H", end="")
        print_banner()
        if title:
            _header(title)
        if intro:
            for line in intro:
                print(f"  {DM}{line}{RS}")
            print()
        for i, label in enumerate(labels):
            if i == idx:
                print(f"  {OR}{BD}›{RS} {label}")
            else:
                print(f"    {label}")
        print(f"\n  {DM}{footer}{RS}")
        key = _read_key()
        if key in ("q", "Q", "esc", "\x03"):
            return None
        elif key == "up":
            idx = (idx - 1) % len(labels)
        elif key == "down":
            idx = (idx + 1) % len(labels)
        elif key in ("\r", "\n"):
            return idx
        elif key.isdigit() and 1 <= int(key) <= min(9, len(labels)):
            return int(key) - 1


def _offer_reload():
    if _confirm("Reload the modifier daemon now to apply changes?", default=True):
        cmd_reload(_NS())
        _pause()


def _action_summary(action):
    """Human-friendly one-liner for a button action string."""
    if action == "button:6":
        return f"{OR}modifier trigger{RS} {DM}(button:6){RS}"
    if action.startswith("button:"):
        return f"{OR}mouse button{RS} {DM}({action}){RS}"
    if action.startswith("key:"):
        return f"{OR}macro{RS} {DM}({action[4:]}){RS}"
    return action


def _capture_combo(timeout=10):
    """Grab the keyboard briefly and return a pressed combo like 'Ctrl+C'.

    The grab keeps the keystrokes from reaching the terminal (so Ctrl+C won't
    abort musfocus). Returns the combo string, or None if cancelled/timed out.
    """
    try:
        import evdev
        from evdev import ecodes as e
    except ImportError:
        return None
    import select as _sel, time

    MODS = {
        e.KEY_LEFTCTRL: "Ctrl", e.KEY_RIGHTCTRL: "Ctrl",
        e.KEY_LEFTSHIFT: "Shift", e.KEY_RIGHTSHIFT: "Shift",
        e.KEY_LEFTALT: "Alt", e.KEY_RIGHTALT: "Alt",
        e.KEY_LEFTMETA: "Super", e.KEY_RIGHTMETA: "Super",
    }
    MOD_ORDER = ["Ctrl", "Shift", "Alt", "Super"]
    code2name = {}
    for ch in "abcdefghijklmnopqrstuvwxyz0123456789":
        code2name[getattr(e, f"KEY_{ch.upper()}")] = ch.upper()
    for n in range(1, 13):
        code2name[getattr(e, f"KEY_F{n}")] = f"F{n}"
    code2name.update({
        e.KEY_BACKSPACE: "Backspace", e.KEY_TAB: "Tab", e.KEY_ENTER: "Enter",
        e.KEY_SPACE: "Space", e.KEY_DELETE: "Delete", e.KEY_INSERT: "Insert",
        e.KEY_HOME: "Home", e.KEY_END: "End", e.KEY_PAGEUP: "PageUp",
        e.KEY_PAGEDOWN: "PageDown", e.KEY_UP: "Up", e.KEY_DOWN: "Down",
        e.KEY_LEFT: "Left", e.KEY_RIGHT: "Right",
    })

    # Skip the configured mouse so we only grab real keyboards.
    skip = set()
    try:
        cfg = load_config().get("device", {})
        skip.add((int(cfg.get("vendor", "0"), 16), int(cfg.get("product", "0"), 16)))
    except Exception:
        pass

    devs = []
    for path in evdev.list_devices():
        try:
            d = evdev.InputDevice(path)
            caps = d.capabilities().get(e.EV_KEY, [])
            is_kbd = all(c in caps for c in (e.KEY_A, e.KEY_Z, e.KEY_SPACE, e.KEY_ENTER))
            if is_kbd and (d.info.vendor, d.info.product) not in skip:
                devs.append(d)
            else:
                d.close()
        except Exception:
            pass
    if not devs:
        print(f"\n  {RD}No readable keyboard found — type it instead.{RS}")
        return None

    for d in devs:
        try:
            d.grab()
        except Exception:
            pass

    if _TTY:
        sys.stdout.write("\033[?25l")
    print(f"\n  {YL}{BD}Press your shortcut now{RS} {DM}(Esc to cancel)...{RS}")

    held, result, fds = set(), None, {d.fd: d for d in devs}
    end = time.time() + timeout
    try:
        while time.time() < end and result is None:
            r, _, _ = _sel.select(list(fds), [], [], end - time.time())
            if not r:
                break
            for fd in r:
                for ev in fds[fd].read():
                    if ev.type != e.EV_KEY:
                        continue
                    code, val = ev.code, ev.value
                    if code == e.KEY_ESC and val == 1:
                        result = "__cancel__"
                        break
                    if val == 1 and code in MODS:
                        held.add(MODS[code])
                    elif val == 0 and code in MODS:
                        held.discard(MODS[code])
                    elif val == 1 and code in code2name:
                        mods = [m for m in MOD_ORDER if m in held]
                        result = "+".join(mods + [code2name[code]])
                        break
                    # live preview of currently held modifiers
                    live = " + ".join(m for m in MOD_ORDER if m in held)
                    sys.stdout.write(f"\r  {DM}holding:{RS} {OR}{live or '—'}{RS}\033[K")
                    sys.stdout.flush()
                if result is not None:
                    break
    finally:
        for d in devs:
            try:
                d.ungrab()
            except Exception:
                pass
            d.close()
        if _TTY:
            sys.stdout.write("\r\033[K\033[?25h")
            sys.stdout.flush()

    if result in (None, "__cancel__"):
        return None
    return result


def _get_combo():
    """Capture or type a key combo. Returns a bare combo like 'Ctrl+C', or None."""
    how = _select("Keyboard shortcut", [
        "⌨ Press the keys now  (capture)",
        "✎ Type it manually    (e.g. Ctrl+Shift+B)",
    ], intro=["Capture lets you just press the real shortcut."])
    if how is None:
        return None
    if how == 0:
        combo = _capture_combo()
        if combo:
            print(f"\n  {GR}✓{RS} Captured: {OR}{BD}{combo}{RS}")
            if _confirm("Use this combo?", default=True):
                return combo
            return None
        print(f"\n  {DM}Nothing captured — type it instead.{RS}")
    c = _ask("Key combo  (e.g. Ctrl+C, Ctrl+Shift+B, Backspace)")
    return c or None


_MOUSE_FUNCS = [
    ("Left click",   "button:1"),
    ("Right click",  "button:2"),
    ("Middle click", "button:3"),
    ("Back  (thumb, rear)",  "button:4"),
    ("Front (thumb, front)", "button:5"),
]


def _choose_mouse_button():
    pick = _select("Which mouse function?", [f"{OR}{lbl}{RS}" for lbl, _ in _MOUSE_FUNCS],
                   intro=["Make this button act as a normal mouse button."])
    return _MOUSE_FUNCS[pick][1] if pick is not None else None


def _choose_action():
    """Action picker. Returns an action string, '' to remove, or None to cancel."""
    opt = _select("What should this button do?", [
        f"{OR}Mouse button{RS}    {DM}left, right, middle, back, forward{RS}",
        f"{OR}Keyboard macro{RS}  {DM}Ctrl+C, Backspace, ...{RS}",
        f"{RD}Remove{RS}",
    ])
    if opt is None:
        return None
    if opt == 0:
        return _choose_mouse_button()
    if opt == 1:
        combo = _get_combo()
        return f"key:{combo}" if combo else None
    return ""  # remove



    default_pat = f"*{wclass.lower()}*" if wclass else ""
    return _ask("Pattern  (* = wildcard, | = or)", default_pat) or None


def _ensure_two_assignments(doc, name):
    """Guarantee a profile has exactly-two 'assignments' (variants).

    Legacy profiles with top-level buttons are migrated into assignment 1 & 2.
    """
    tk = _tomlkit()
    prof = doc["profile"][name]
    variants = prof.get("variants")
    if not variants:
        base = {k: prof[k] for k in list(prof.keys()) if k not in ("variants", "active")}
        if not any(k for k in base if k not in ("dpi", "layer2")):
            base = {"dpi": base.get("dpi", 400), "3": "button:5",
                    "4": "button:4", "5": "button:6"}
        for k in list(prof.keys()):
            if k not in ("variants", "active"):
                del prof[k]
        prof["variants"] = tk.table()
        for an in ("assignment 1", "assignment 2"):
            t = tk.table()
            for k, v in base.items():
                t[k] = v
            prof["variants"][an] = t
        prof["active"] = "assignment 1"
        return
    names = list(variants.keys())
    while len(prof["variants"]) < 2:
        src = prof["variants"][names[0]]
        t = tk.table()
        for k in src:
            t[k] = src[k]
        prof["variants"][f"assignment {len(prof['variants']) + 1}"] = t
        names = list(prof["variants"].keys())
    if prof.get("active") not in prof["variants"]:
        prof["active"] = list(prof["variants"].keys())[0]


def _new_profile():
    pattern = _choose_app_pattern()        # ask the app FIRST
    name = _ask("Profile name  (e.g. blender)")
    if not name:
        return
    doc = _load_doc()
    if doc.get("profile") is None:
        doc["profile"] = _tomlkit().table()
    if name in doc["profile"]:
        print(f"\n  {RD}Profile {name!r} already exists.{RS}")
        _pause()
        return name
    dpi = _ask("DPI for this profile", "400")
    prof = _tomlkit().table()
    if dpi and dpi.isdigit():
        prof["dpi"] = int(dpi)
    doc["profile"][name] = prof
    _ensure_two_assignments(doc, name)     # gives it assignment 1 & 2
    if pattern:
        if doc.get("apps") is None:
            doc["apps"] = _tomlkit().table()
        doc["apps"][pattern] = name
    _save_doc(doc)
    for_app = f" for {OR}{pattern}{RS}" if pattern else ""
    print(f"\n  {GR}✓{RS} Created {OR}{BD}{name}{RS}{for_app}. {DM}Set it up next.{RS}")
    _pause()
    _edit_profile(name)
    return name


def _profile_apps(name):
    while True:
        doc = _load_doc()
        apps = doc.get("apps", {})
        mine = [p for p, who in apps.items() if who == name]
        labels = [f"{OR}{p}{RS}" for p in mine]
        labels.append(f"{GR}+ assign an app{RS}")
        choice = _select(f"{name} · apps", labels,
                         intro=["Apps that load this profile when focused."],
                         footer="↑↓ · enter · q back")
        if choice is None:
            return
        if choice == len(mine):
            pat = _choose_app_pattern()
            if pat:
                if doc.get("apps") is None:
                    doc["apps"] = _tomlkit().table()
                doc["apps"][pat] = name
                _save_doc(doc)
        else:
            p = mine[choice]
            what = _select(f"App: {p}", ["Change pattern", f"{RD}Remove{RS}"])
            if what == 0:
                new = _ask("New pattern", p)
                if new and new != p:
                    del doc["apps"][p]
                    doc["apps"][new] = name
                    _save_doc(doc)
            elif what == 1:
                if _confirm(f"Remove {p!r}?", default=False):
                    del doc["apps"][p]
                    _save_doc(doc)


def _edit_profile(name):
    # Every profile carries exactly two assignments (switchable layouts).
    doc = _load_doc()
    if name not in doc.get("profile", {}):
        return
    _ensure_two_assignments(doc, name)
    _save_doc(doc)

    if not (_TTY and sys.stdin.isatty()):
        return

    idx = 0   # cursor: 0 Apps · 1/2 tabs · 3 Buttons · 4 Second layer · 5 DPI · 6 Rename · 7 Delete
    while True:
        doc = _load_doc()
        prof = doc.get("profile", {}).get(name)
        if prof is None:
            return
        variants = prof.get("variants") or {}
        anames = list(variants.keys())
        if len(anames) < 2:
            _ensure_two_assignments(doc, name)
            _save_doc(doc)
            continue
        a1, a2 = anames[0], anames[1]
        active = prof.get("active") if prof.get("active") in variants else a1
        act = variants[active]
        nbtn = len([k for k in act if k not in _PROFILE_META])
        l2 = act.get("layer2") or {}
        nsh = len([k for k in l2 if k in _BTN_FRIENDLY])
        adpi = act.get("dpi", "—")
        mine = [p for p, who in doc.get("apps", {}).items() if who == name]
        app_note = ", ".join(mine) if mine else "none yet"

        print("\033[2J\033[H", end="")
        print_banner()
        _header(f"Profile · {name}")

        def row(i, text):
            mark = f"{OR}{BD}›{RS} " if idx == i else "  "
            print(f"  {mark}{text}")

        sep = f"  {DM}{'─' * 44}{RS}"

        row(0, f"{BD}Apps{RS}   {DM}{app_note}{RS}")
        print(sep)

        def tab(i, an):
            is_act = an == active
            dot = f"{GR}●{RS}" if is_act else f"{DM}○{RS}"
            txt = f"{GR}{BD}{an}{RS}" if is_act else f"{DM}{an}{RS}"
            inner = f"{dot} {txt}"
            return f"{OR}{BD}▸{RS}{inner}{OR}{BD}◂{RS}" if idx == i else f" {inner} "
        print(f"   {tab(1, a1)}       {tab(2, a2)}")
        print(f"   {DM}active = green; Enter on a tab makes it active{RS}")
        print(sep)

        row(3, f"{BD}Buttons{RS}        {DM}{nbtn} set{RS}")
        row(4, f"{BD}Second layer{RS}   {DM}{nsh} shortcut(s){RS}")
        row(5, f"{BD}DPI{RS}            {OR}{adpi}{RS}")
        print(sep)
        row(6, "Rename profile")
        row(7, f"{RD}Delete profile{RS}")
        print(f"\n  {DM}↑↓ move · ←→ switch tab · Enter select · q back{RS}")

        key = _read_key()
        if key in ("q", "Q", "esc", "\x03"):
            return
        elif key == "up":
            idx = (idx - 1) % 8
        elif key == "down":
            idx = (idx + 1) % 8
        elif key == "left" and idx == 2:
            idx = 1
        elif key == "right" and idx == 1:
            idx = 2
        elif key in ("\r", "\n"):
            if idx == 0:
                _profile_apps(name)
            elif idx in (1, 2):
                prof["active"] = a1 if idx == 1 else a2
                _save_doc(doc)
                _apply_now()
            elif idx == 3:
                _variant_buttons(name, active)
            elif idx == 4:
                _variant_layer2(name, active)
            elif idx == 5:
                new = _ask("DPI", str(adpi if adpi != "—" else "400"))
                if new and new.isdigit():
                    act["dpi"] = int(new)
                    _save_doc(doc)
                    _apply_now()
            elif idx == 6:
                new = _ask("New name", name)
                if new and new != name:
                    doc["profile"][new] = dict(prof)
                    del doc["profile"][name]
                    for p, who in list(doc.get("apps", {}).items()):
                        if who == name:
                            doc["apps"][p] = new
                    _save_doc(doc)
                    name = new
            elif idx == 7:
                if _confirm(f"Delete profile {name!r}?", default=False):
                    del doc["profile"][name]
                    for p, who in list(doc.get("apps", {}).items()):
                        if who == name:
                            del doc["apps"][p]
                    _save_doc(doc)
                    return


_PROFILE_META = ("dpi", "layer2", "variants", "active")


def _buttons_screen(name):
    while True:
        doc = _load_doc()
        prof = doc["profile"][name]
        btn_keys = [k for k in prof.keys() if k not in _PROFILE_META]
        labels = [f"{OR}button {k}{RS}  {DM}→{RS}  {_action_summary(str(prof[k]))}"
                  for k in btn_keys]
        labels.append(f"{GR}+ set a button{RS}")
        choice = _select(f"{name} · buttons", labels,
                         intro=["Pick a button to change what it does."],
                         footer="↑↓ · enter · q back")
        if choice is None:
            return
        if choice == len(btn_keys):          # add
            idx = _pick_button_index()
            if not idx:
                continue
            act = _choose_action()
            if act in (None, ""):
                continue
            if not _set_button(prof, idx, act):
                continue
            _save_doc(doc)
            _offer_reload()
        else:                                # edit existing
            k = btn_keys[choice]
            act = _choose_action()
            if act is None:
                continue
            if act == "":
                del prof[k]
            elif not _set_button(prof, k, act):
                continue
            _save_doc(doc)
            _offer_reload()


def _ensure_layer2(doc, name):
    """Return the profile's own layer2 table, seeding it from shared defaults once."""
    prof = doc["profile"][name]
    if prof.get("layer2") is None:
        tbl = _tomlkit().table()
        for k, v in doc.get("modifier", {}).items():
            if k in _BTN_FRIENDLY:
                tbl[k] = str(v)
        prof["layer2"] = tbl
    return prof["layer2"]


def _set_trigger(doc, name):
    print(f"\n  {DM}Pick the button you'll HOLD to reach the second layer.{RS}")
    _pause("press any key to choose")
    idx = _pick_button_index()
    if not idx:
        return
    prof = doc["profile"][name]
    for k in [k for k, v in list(prof.items()) if str(v) == "button:6" and k != idx]:
        del prof[k]
    prof[idx] = "button:6"
    _save_doc(doc)
    print(f"\n  {GR}✓{RS} Trigger set — hold button {idx} to reach the second layer.")
    _offer_reload()


def _layer2_screen(name):
    while True:
        doc = _load_doc()
        prof = doc["profile"][name]
        l2 = prof.get("layer2")
        inherited = l2 is None
        src = (l2 if not inherited else doc.get("modifier", {}))
        binds = [(k, str(src[k])) for k in src if k in _BTN_FRIENDLY]
        trig = next((k for k, v in prof.items() if str(v) == "button:6"), None)
        trig_lbl = "not set" if trig is None else f"button {trig}"
        intro = ["Hold the trigger button, then click another button → fires a shortcut."]
        if inherited:
            intro.append(f"{YL}Using shared defaults — add one to make this profile's own.{RS}")
        labels = [f"{DM}trigger{RS}  {OR}{trig_lbl}{RS} {DM}(hold this){RS}"]
        for k, v in binds:
            labels.append(f"{_BTN_FRIENDLY.get(k, k):<20} {DM}→{RS}  {OR}{v}{RS}")
        labels.append(f"{GR}+ add shortcut{RS}")
        choice = _select(f"{name} · second layer", labels, intro=intro,
                         footer="↑↓ · enter · q back")
        if choice is None:
            return
        if choice == 0:
            _set_trigger(doc, name)
        elif 1 <= choice <= len(binds):
            k, v = binds[choice - 1]
            what = _select(f"{_BTN_FRIENDLY.get(k, k)}  →  {v}",
                           ["Change shortcut", f"{RD}Remove{RS}"])
            if what == 0:
                combo = _get_combo()
                if combo:
                    _ensure_layer2(doc, name)[k] = combo
                    _save_doc(doc)
                    _offer_reload()
            elif what == 1:
                if _confirm(f"Remove {_BTN_FRIENDLY.get(k, k)} → {v}?", default=False):
                    layer = _ensure_layer2(doc, name)
                    if k in layer:
                        del layer[k]
                    _save_doc(doc)
                    _offer_reload()
        elif choice == 1 + len(binds):
            btn = _pick_btn_name()
            if not btn:
                continue
            print(f"\n  {DM}Set the shortcut for {_BTN_FRIENDLY.get(btn, btn)}.{RS}")
            combo = _get_combo()
            if not combo:
                continue
            _ensure_layer2(doc, name)[btn] = combo
            _save_doc(doc)
            print(f"\n  {GR}✓{RS} {_BTN_FRIENDLY.get(btn, btn)} {DM}→{RS} {OR}{combo}{RS}")
            _offer_reload()



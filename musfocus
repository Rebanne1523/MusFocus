def _variant_actions(name, vn):
    doc = _load_doc()
    prof = doc["profile"][name]
    is_active = prof.get("active") == vn
    choice = _select(f"{name} · {vn}", [
        f"{GR}Use this one{RS}" + (f" {DM}(active){RS}" if is_active else ""),
        "Edit buttons",
        f"{DM}Rename{RS}",
        f"{RD}Delete{RS}",
    ], intro=["Enter to choose an action."])
    if choice is None:
        return
    if choice == 0:
        prof["active"] = vn
        _save_doc(doc)
        _apply_now()
        print(f"\n  {GR}✓{RS} {OR}{vn}{RS} is now active for {name}.")
        _pause()
    elif choice == 1:
        _variant_buttons(name, vn)
    elif choice == 2:
        new = _ask("New assignment name", vn)
        if new and new != vn:
            prof["variants"][new] = dict(prof["variants"][vn])
            del prof["variants"][vn]
            if prof.get("active") == vn:
                prof["active"] = new
            _save_doc(doc)
            _apply_now()
    elif choice == 3:
        if _confirm(f"Delete assignment {vn!r}?", default=False):
            del prof["variants"][vn]
            if prof.get("active") == vn:
                del prof["active"]
            if not prof["variants"]:
                del prof["variants"]
            _save_doc(doc)
            _apply_now()


def _new_variant(name):
